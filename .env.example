# DRP — shared environment template.
# Copy to .env and fill in real values. NEVER commit the real .env.
# Get Supabase values from: Supabase Dashboard -> Connect.

# --- Supabase (Postgres + pgvector) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_PASSWORD=your-supabase-db-password
SUPABASE_CONNECTION_STRING=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=supabase-service-role-key

# --- OpenAI (gateway: commander data-chat LLM) ---
OPENAI_API_KEY=sk-proj-xxx

# --- Auth (local dev only) ---
# In production UDS Authservice supplies the identity via a JWT; these are ignored.
# For local dev without Authservice, set BACKEND_DEBUG=true and pick a persona the
# backend should run as (or send X-Dev-Role / X-Dev-Edipi headers per request).
# See docs/configuration.md.
BACKEND_DEBUG=true
# DEV_ROLE: commander | provider | service_member  (empty = anonymous / 401)
DEV_ROLE=
# DEV_EDIPI: resolves to a service_members row for member/unit scoping.
DEV_EDIPI=

SENDGRID_API_KEY=SG.xxxx
SENDGRID_FROM_EMAIL=your-email@example.com
SCHEDULER_ENABLED=true


