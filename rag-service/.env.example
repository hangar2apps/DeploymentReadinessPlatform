# rag-service (DocIntel) environment template.
# Copy to .env and fill in real values. server.py reads DB_* + OPENAI_API_KEY.
# Parse DB_* from your Supabase connection string (Supabase Dashboard -> Connect).

# --- OpenAI (embeddings + LLM) ---
OPENAI_API_KEY=sk-proj-xxx

# --- Supabase Postgres (direct connection) ---
DB_HOST=db.YOUR_PROJECT.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
DB_SSLMODE=require

# IPv6 fallback: if the direct host won't resolve, use the session pooler:
#   DB_HOST=aws-0-<region>.pooler.supabase.com
#   DB_USER=postgres.YOUR_PROJECT
